rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: email, displayName, role, subscriptionStatus, createdAt
    //
    // Collection: appConfig
    // Fields: appName, logoUrl, footerLogoUrl, footerName, createdAt
    //
    // Collection: giftCards
    // Fields: name, brandId, categoryId, imageUrl, price, description, createdAt
    //
    // Collection: categories
    // Fields: name, imageUrl, createdAt
    //
    // Collection: brands
    // Fields: name, imageUrl, createdAt
    //
    // Collection: subscriptionPlans
    // Fields: name, price, features, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ovmepos@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'subscriptionStatus']) &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.subscriptionStatus in ['free', 'premium'];
    }

    function isValidAppConfig(data) {
      return data.keys().hasAll(['appName', 'logoUrl']) &&
             data.appName is string && data.appName.size() > 0 &&
             data.logoUrl is string;
    }

    function isValidGiftCard(data) {
      return data.keys().hasAll(['name', 'brandId', 'categoryId', 'imageUrl', 'price']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'imageUrl']) &&
             data.name is string && data.name.size() > 0;
    }

    function isValidBrand(data) {
      return data.keys().hasAll(['name', 'imageUrl']) &&
             data.name is string && data.name.size() > 0;
    }

    function isValidSubscriptionPlan(data) {
      return data.keys().hasAll(['name', 'price', 'features']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.features is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin() && isValidAppConfig(request.resource.data);
    }

    match /giftCards/{cardId} {
      allow read: if true;
      allow write: if isAdmin() && isValidGiftCard(request.resource.data);
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCategory(request.resource.data);
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin() && isValidBrand(request.resource.data);
    }

    match /subscriptionPlans/{planId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSubscriptionPlan(request.resource.data);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
