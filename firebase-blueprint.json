{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "costPrice": { "type": "number" },
        "sellPrice": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "hasVariants": { "type": "boolean" },
        "variants": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "color": { "type": "string" },
              "size": { "type": "string" },
              "stock": { "type": "number" }
            }
          }
        },
        "vendorId": { "type": "string" }
      },
      "required": ["id", "sku", "name", "sellPrice", "stock", "category"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A sales record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "number" },
        "items": { "type": "array" },
        "subTotal": { "type": "number" },
        "discount": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "processedBy": { "type": "string" },
        "vendorId": { "type": "string" }
      },
      "required": ["id", "timestamp", "items", "total", "paymentMethod"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string" },
        "email": { "type": "string" },
        "vendorId": { "type": "string" }
      },
      "required": ["id", "name", "role"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A customer booking/appointment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "number" },
        "customerName": { "type": "string" },
        "customerMobile": { "type": "string" },
        "customerAddress": { "type": "string" },
        "bookingDate": { "type": "string" },
        "status": { "type": "string" },
        "notes": { "type": "string" },
        "serviceType": { "type": "string" },
        "vendorId": { "type": "string" }
      },
      "required": ["customerName", "customerMobile", "bookingDate", "status"]
    },
    "StockHistory": {
      "title": "StockHistory",
      "description": "A log of stock adjustments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "sku": { "type": "string" },
        "oldStock": { "type": "number" },
        "newStock": { "type": "number" },
        "adjustment": { "type": "number" },
        "type": { "type": "string" },
        "timestamp": { "type": "number" },
        "reason": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["productId", "oldStock", "newStock", "timestamp"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["name"]
    },
    "Brand": {
      "title": "Brand",
      "description": "A partner brand",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "vendorId": { "type": "string" }
      },
      "required": ["name", "logo"]
    },
    "GiftCard": {
      "title": "GiftCard",
      "description": "A gift card",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "discount": { "type": "string" },
        "vendorId": { "type": "string" }
      },
      "required": ["name", "icon", "discount"]
    },
    "PremiumPlan": {
      "title": "PremiumPlan",
      "description": "A premium subscription plan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "isPopular": { "type": "boolean" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["name", "price", "duration", "features"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory products"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records"
    },
    "/profiles/{profileId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Customer bookings"
    },
    "/stock_history/{historyId}": {
      "schema": "StockHistory",
      "description": "Stock adjustment history"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/brands/{brandId}": {
      "schema": "Brand",
      "description": "Partner brands"
    },
    "/giftCards/{giftCardId}": {
      "schema": "GiftCard",
      "description": "Gift cards"
    },
    "/premium_plans/{planId}": {
      "schema": "PremiumPlan",
      "description": "Premium subscription plans"
    }
  }
}
